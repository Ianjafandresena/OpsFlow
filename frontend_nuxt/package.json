{
  "name": "frontend-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "build:prod": "chmod -R +x node_modules/.bin && npx prisma generate && npx prisma db push && nuxt build",
    "db:migrate": "npx prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.14.0",
    "googleapis": "^173.0.0",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^3.11.2",
    "prisma": "^5.14.0",
    "tsx": "^4.10.5",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {},
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
