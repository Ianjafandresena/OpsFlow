generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")  // Neon: direct connection for migrations (bypasses PgBouncer)
}

model Departement {
  id              String  @id @default(uuid())
  nom_departement String  @unique
  postes          Poste[]
}

model Poste {
  id            String      @id @default(uuid())
  titre_poste   String
  departementId String
  employes      Employe[]
  departement   Departement @relation(fields: [departementId], references: [id])
}

model Role {
  id           String    @id @default(uuid())
  niveau_acces String    @unique
  employes     Employe[]
}

model Employe {
  id             String        @id @default(uuid())
  nom            String
  prenom         String
  email          String        @unique
  mot_de_passe   String?
  is_active      Boolean       @default(false)
  salaire_base   Float?
  posteId        String
  roleId         String
  poste          Poste         @relation(fields: [posteId], references: [id])
  role           Role          @relation(fields: [roleId], references: [id])
  taches         Tache[]
  editionsGerees EditionPage[] @relation("EditionPageToEmploye")
  journals1      Journal[]     @relation("JournalEmploye1")
  journals2      Journal[]     @relation("JournalEmploye2")
  journals3      Journal[]     @relation("JournalEmploye3")
  journals4      Journal[]     @relation("JournalEmploye4")
  entreesJournal EntreeJournal[]
  reglements     ReglementEmploye[]
  tachesLues     TacheLue[]
  notifications  NotificationEmploye[]
  entreeJournalsEditees  EntreeJournal[]  @relation("EntreeJournalEditeur")
  journalAcces           JournalAcces[]
  evaluations            EvaluationSalaire[]
  memos      Memo[]   @relation("MemoAuteur")
  liensCreees    LienImportant[] @relation("LienImportantAuteur")
  liensModifies  LienImportant[] @relation("LienImportantModifiePar")
}

model Licence {
  id          String        @id @default(uuid())
  nom_complet String
  sigle       String        @unique
  editions    EditionPage[]
}

model Ville {
  id                 String        @id @default(uuid())
  nom_ville          String        @unique
  statut             String?       @default("NEUTRE")
  statut_commentaire String?       @db.Text
  editions           EditionPage[]
}

model EditionPage {
  id         String    @id @default(uuid())
  date_debut DateTime?
  date_fin   DateTime?
  licenceId  String
  villeId    String
  metaPageId String?   // ID de la page Meta associée (Facebook/Instagram)
  licence    Licence   @relation(fields: [licenceId], references: [id])
  ville      Ville     @relation(fields: [villeId], references: [id])
  taches     Tache[]
  employes   Employe[] @relation("EditionPageToEmploye")
  journals   JournalEdition[]

  @@unique([licenceId, villeId])
}

model Theme {
  id           String  @id @default(uuid())
  nom_theme    String  @unique
  tachesPub    Tache[] @relation("ThemePublication")
  tachesSponso Tache[] @relation("ThemeSponsorisation")
}

model StatutTache {
  id      String  @id @default(uuid())
  libelle String  @unique
  taches  Tache[]
}

model Tache {
  id             String       @id @default(uuid())
  typeTache      TypeTache
  titre          String
  description    String?
  date_limite    DateTime
  lien_livrable  String?
  createdAt      DateTime     @default(now())
  employeId      String
  editionId      String?
  statutTacheId  String
  plateforme     String?
  type_pub       String?
  themePubId     String?
  themeSponsoId  String?
  budget         Float?
  audience       String?
  format_video   String?
  duree_cible    String?
  demandeur      String?
  type_visuel    String?
  quantite       Int?
  type_technique String?
  type_demarche  String?
  date_demande   DateTime?
  date_resultat  DateTime?
  outil_mailing  String?
  execution      Execution?
  edition        EditionPage? @relation(fields: [editionId], references: [id])
  employe        Employe      @relation(fields: [employeId], references: [id])
  statutTache    StatutTache  @relation(fields: [statutTacheId], references: [id])
  themePub       Theme?       @relation("ThemePublication", fields: [themePubId], references: [id])
  themeSponso    Theme?       @relation("ThemeSponsorisation", fields: [themeSponsoId], references: [id])
  aVerifier          Boolean   @default(false)
  motifModification  String?   @db.Text
  demandes       DemandeTache[]
  entreesJournal EntreeJournal[]
  tachesLues     TacheLue[]
}

model Execution {
  id          String      @id @default(uuid())
  date_reelle DateTime?
  url_live    String?
  tacheId     String      @unique
  evaluation  Evaluation?
  tache       Tache       @relation(fields: [tacheId], references: [id], onDelete: Cascade)
}

model Evaluation {
  id             String    @id @default(uuid())
  score_qualite  Int?
  commentaire_ia String?
  executionId    String    @unique
  execution      Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
}

model DemandeTache {
  id           String   @id @default(uuid())
  typeDemande  String   // "MODIFICATION" ou "SUPPRESSION"
  statut       String   @default("EN_ATTENTE") // "EN_ATTENTE", "ACCEPTEE", "REFUSEE"
  motif        String
  donneesModif String?  // JSON string
  createdAt    DateTime @default(now())
  tacheId      String
  tache        Tache    @relation(fields: [tacheId], references: [id], onDelete: Cascade)
}

enum TypeTache {
  PUBLICATION
  SPONSORISATION
  MONTEUR
  DESIGNER
  DEV
  MAILING
  ADMINISTRATIVE
}

model Journal {
  id          String   @id @default(uuid())
  nom         String
  createdAt   DateTime @default(now())
  visibiliteMode    String   @default("TOUS")

  employe1Id  String
  employe1    Employe  @relation("JournalEmploye1", fields: [employe1Id], references: [id])

  employe2Id  String?
  employe2    Employe? @relation("JournalEmploye2", fields: [employe2Id], references: [id])

  employe3Id  String?
  employe3    Employe? @relation("JournalEmploye3", fields: [employe3Id], references: [id])

  employe4Id  String?
  employe4    Employe? @relation("JournalEmploye4", fields: [employe4Id], references: [id])

  groupeId   String?
  groupe     GroupeJournal? @relation(fields: [groupeId], references: [id], onDelete: SetNull)

  entrees     EntreeJournal[]
  editions    JournalEdition[]
  acces       JournalAcces[]
  evaluations EvaluationSalaire[]
  memos      Memo[]
}

model JournalAcces {
  id         String   @id @default(uuid())
  journalId  String
  employeId  String
  peutEditer Boolean  @default(false)
  journal    Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  employe    Employe  @relation(fields: [employeId], references: [id], onDelete: Cascade)
  @@unique([journalId, employeId])
}

model EntreeJournal {
  id          String   @id @default(uuid())
  date        DateTime @db.Date
  heure       String   // e.g. "08:30"
  contenu     String   @db.Text
  commentaire       String?  @db.Text
  admin_commentaire String?  @db.Text
  lien              String?
  recherches        String?  @db.Text
  heure_affichage   String?
  heure_fin         String?
  evaluation_type   String?
  evaluation_montant Float?
  reportee          Boolean   @default(false)
  tacheTerminee     Boolean   @default(false)
  aVerifier         Boolean   @default(false)
  motifModification String?   @db.Text

  journalId   String
  journal     Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)

  employeId   String
  employe     Employe  @relation(fields: [employeId], references: [id], onDelete: Cascade)

  tacheId     String?
  tache       Tache?   @relation(fields: [tacheId], references: [id], onDelete: SetNull)

  editeurId   String?
  editeur     Employe? @relation("EntreeJournalEditeur", fields: [editeurId], references: [id], onDelete: SetNull)

  commentaires CommentaireJournal[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([journalId, employeId, date, heure])
}

model CommentaireJournal {
  id        String        @id @default(uuid())
  contenu   String        @db.Text
  isAdmin   Boolean       @default(false)
  auteur    String
  createdAt DateTime      @default(now())
  entreeId  String
  entree    EntreeJournal @relation(fields: [entreeId], references: [id], onDelete: Cascade)
}

model JournalEdition {
  journalId String
  editionId String
  journal   Journal     @relation(fields: [journalId], references: [id], onDelete: Cascade)
  edition   EditionPage @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@id([journalId, editionId])
}

model Reglement {
  id        String             @id @default(uuid())
  titre     String
  contenu   String             @db.Text
  createdAt DateTime           @default(now())
  employes  ReglementEmploye[]
}

model ReglementEmploye {
  reglementId String
  employeId   String
  reglement   Reglement @relation(fields: [reglementId], references: [id], onDelete: Cascade)
  employe     Employe   @relation(fields: [employeId], references: [id], onDelete: Cascade)

  @@id([reglementId, employeId])
}

model TacheLue {
  id        String   @id @default(uuid())
  tacheId   String
  employeId String
  luAt      DateTime @default(now())
  tache     Tache    @relation(fields: [tacheId], references: [id], onDelete: Cascade)
  employe   Employe  @relation(fields: [employeId], references: [id], onDelete: Cascade)

  @@unique([tacheId, employeId])
}

model NotificationEmploye {
  id        String   @id @default(uuid())
  type      String   // NOUVELLE_TACHE | COMMENTAIRE | REGLEMENT | A_MODIFIER
  message   String
  lue       Boolean  @default(false)
  refId     String?
  employeId String
  employe   Employe  @relation(fields: [employeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model EvaluationSalaire {
  id         String   @id @default(uuid())
  employeId  String
  journalId  String?
  mois       Int
  annee      Int
  type       String   // PRIME | PENALITE
  montant    Float
  motif      String
  statut     String   @default("ACQUIS") // ACQUIS | A_VOIR
  createdAt  DateTime @default(now())
  employe    Employe  @relation(fields: [employeId], references: [id], onDelete: Cascade)
  journal    Journal? @relation(fields: [journalId], references: [id], onDelete: SetNull)
}

model Memo {
  id        String   @id @default(uuid())
  contenu   String   @db.Text
  liens     String?  @db.Text
  auteurId  String
  journalId String
  createdAt DateTime @default(now())
  auteur    Employe  @relation("MemoAuteur", fields: [auteurId], references: [id], onDelete: Cascade)
  journal   Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
}

model GroupeJournal {
  id        String    @id @default(uuid())
  nom       String
  createdAt DateTime  @default(now())
  journaux  Journal[]
}

model LienImportant {
  id           String    @id @default(uuid())
  titre        String
  description  String?   @db.Text
  url          String
  auteurId     String
  auteur       Employe   @relation("LienImportantAuteur", fields: [auteurId], references: [id], onDelete: Cascade)
  modifieParId String?
  modifiePar   Employe?  @relation("LienImportantModifiePar", fields: [modifieParId], references: [id], onDelete: SetNull)
  modifieLeAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
