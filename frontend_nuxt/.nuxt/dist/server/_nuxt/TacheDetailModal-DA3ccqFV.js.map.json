{"file":"TacheDetailModal-DA3ccqFV.js","mappings":";;;;;;;;;;;;;AAmMA,UAAM,QAAQ;AAOd,UAAM,SAAS,SAAS,MAAM;AAC5B,UAAI,CAAC,MAAM,OAAO,YAAa,QAAO;AACtC,YAAM,KAAK,MAAM,OAAO,aAAa;AACrC,UAAI,OAAO,aAAa,OAAO,SAAU,QAAO;AAChD,aAAO,IAAI,KAAK,MAAM,MAAM,WAAW,IAAI,oBAAI,KAAI;AAAA,IACrD,CAAC;AAED,UAAM,aAAa,CAAC,MAAM;AACxB,UAAI,CAAC,EAAG,QAAO;AACf,aAAO,IAAI,KAAK,CAAC,EAAE,eAAe,SAAS,EAAE,WAAW,SAAS,WAAW,QAAO,CAAE;AAAA,IACvF;AAEA,UAAM,kBAAkB,CAAC,MAAM;AAC7B,UAAI,CAAC,EAAG,QAAO;AACf,aAAO,IAAI,KAAK,CAAC,EAAE,mBAAmB,OAAO;AAAA,IAC/C;AAEA,UAAM,kBAAkB,CAAC,QAAQ;AAC/B,UAAI,CAAC,IAAK,QAAO,CAAA;AACjB,UAAI;AAAE,eAAO,KAAK,MAAM,GAAG;AAAA,MAAE,QAAQ;AAAE,eAAO,IAAI,MAAM,GAAG,EAAE,IAAI,OAAK,EAAE,KAAI,CAAE;AAAA,MAAE;AAAA,IAClF;;+BA7NE,CA2LWA,WAAA;YA1LE,QAAA,QAAM;qLAIN,EAAA,WAAA,QAAA,eAAA,UAAA,OAAA,WAAA,QAAA,KAAA,aAAA,IAAA,CAA2E,CAAA,kEAAA;AAElE,UAAAA,OAAAC,mBAAAC,MAAAC,GAAA,GAAA,EAAA,MAAM,GAAE,GAAA,MAAA,OAAA,CAAA;qDAEf,EAAA,aAAA,IAAA,CAAoB,iDAClB,EAAA,eAAA,OAAA,aAAA,aAAA,eAAA,UAAA,YAAA,UAAA,iBAAA,WAAA,CAA0G,sBAAIC,eAAA,QAAA,OAAO,KAAK,qCAC1H,EAAA,aAAA,WAAA,SAAA,yBAAA,cAAA,MAAA,CAAuE,uFAK3E,EAAA,WAAA,QAAA,eAAA,UAAA,OAAA,WAAA,eAAA,IAAA,CAAqE;AAC5D,cAAA,QAAA,OAAO,aAAW;iDAAqCC,eAAA,EAAA,YAAA,QAAA,MAAM,YAAY,uBAAuB,QAAA,MAAM,YAAY,SAAO,QAAA,eAAyB,QAAA,MAAM,YAAY,QAAO,CAAA,qCAClL,QAAA,MAAM,YAAY,GAAG;;;;;AAGhB,UAAAL,OAAAC,mBAAAC,MAAAI,CAAA,GAAA,EAAA,MAAM,GAAE,GAAA,MAAA,OAAA,CAAA;;AAYgB,cAAA,QAAA,OAAO,SAAO;gOAGZF,eAAA,QAAA,MAAM,QAAQ,QAAQ,OAAM,CAAA,CAAA,IAASA,eAAA,QAAA,MAAM,QAAQ,KAAK,OAAM,CAAA,CAAA,0BACzF,QAAA,MAAM,QAAQ,MAAM,oBAAO,QAAA,MAAM,QAAQ,GAAG;;;;AAGnB,cAAA,QAAA,OAAO,SAAO;0KAEfA,eAAA,QAAA,MAAM,QAAQ,SAAS,KAAK,OAASA,eAAA,QAAA,MAAM,QAAQ,OAAO,SAAS;;;;AAElE,cAAA,QAAA,OAAO,WAAS;AAEjB,YAAAJ,OAAA,gJAAAI,eAAA,QAAA,MAAM,SAAS,CAAA,cAAA;AAAA;;;AAEd,cAAA,QAAA,OAAO,aAAW;yJAENC,eAAA,EAAA,OAAA,OAAA,wDAAyD,OAAA,QAAM,QAAA,MAAA,CAAA,qCACpG,WAAW,QAAA,MAAM,WAAW,CAAA;gBACnB,OAAA,OAAM;oDAAE,EAAA,aAAA,UAAA,eAAA,MAAA,CAA0C,CAAA,qCAAA;AAAA;;;;;;;AAGlC,cAAA,QAAA,OAAO,WAAS;iLAEjB,WAAW,QAAA,MAAM,SAAS,CAAA,CAAA,cAAA;AAAA;;;;AAM3B,cAAA,QAAA,OAAO,cAAc,QAAA,OAAO,UAAQ;;AAGlC,gBAAA,QAAA,OAAO,YAAU;6KAErB,EAAA,WAAA,QAAA,OAAA,UAAA,aAAA,OAAA,CAAiD,CAAA,4BAAA;AACtDE,4BAAA,gBAAgB,QAAA,MAAM,UAAU,IAAtC,OAAE;2FAAgF,EAAE,CAAA,SAAA;AAAA;;;;;AAGrE,gBAAA,QAAA,OAAO,UAAQ;AAEkB,cAAAP,OAAA,4MAAAI,eAAA,QAAA,MAAM,QAAQ,CAAA,qBAAA;AAAA;;;AAE/C,gBAAA,QAAA,OAAO,UAAQ;wLAEhB,QAAA,MAAM,UAAU,SAAS,CAAA,cAAA;AAAA;;;;;;;AAM1B,cAAA,QAAA,OAAO,eAAa;AAKnB,YAAAJ,OAAA,2TAAAI,eAAA,QAAA,MAAM,aAAa,CAAA,cAAA;AAElB,gBAAA,QAAA,OAAO,cAAY;8LAEpB,gBAAgB,QAAA,MAAM,YAAY,CAAA,CAAA,cAAA;AAAA;;;AAEjC,gBAAA,QAAA,OAAO,eAAa;+LAErB,gBAAgB,QAAA,MAAM,aAAa,CAAA,CAAA,cAAA;AAAA;;;;;;;AAMpC,cAAA,QAAA,OAAO,eAAa;AAKY,YAAAJ,OAAA,4VAAAI,eAAA,QAAA,MAAM,aAAa,CAAA,iCAAA;AAAA;;;AAMnD,cAAA,QAAA,OAAO,UAAU,QAAA,OAAO,UAAQ;;AAG9B,gBAAA,QAAA,OAAO,aAAW;8LAEnB,QAAA,MAAM,aAAa,SAAS,CAAA,cAAA;AAAA;;;AAE3B,gBAAA,QAAA,OAAO,QAAM;+KAEjB,EAAA,eAAA,OAAA,SAAA,wBAAA,CAAqD,sBAAIA,eAAA,QAAA,MAAM,MAAM;;;;AAEjE,gBAAA,QAAA,OAAO,UAAQ;AAEhB,cAAAJ,OAAA,yJAAAI,eAAA,QAAA,MAAM,QAAQ,CAAA,cAAA;AAAA;;;;;;;AAMf,cAAA,QAAA,OAAO,gBAAgB,QAAA,OAAO,aAAW;;AAGvC,gBAAA,QAAA,OAAO,cAAY;AAEc,cAAAJ,OAAA,qMAAAI,eAAA,QAAA,MAAM,YAAY,CAAA,qBAAA;AAAA;;;AAEnD,gBAAA,QAAA,OAAO,aAAW;AAEnB,cAAAJ,OAAA,kJAAAI,eAAA,QAAA,MAAM,WAAW,CAAA,cAAA;AAAA;;;;;;;AAMlB,cAAA,QAAA,OAAO,eAAe,QAAA,OAAO,UAAQ;;AAGnC,gBAAA,QAAA,OAAO,aAAW;AAEe,cAAAJ,OAAA,uMAAAI,eAAA,QAAA,MAAM,WAAW,CAAA,qBAAA;AAAA;;;AAElD,gBAAA,QAAA,OAAO,UAAQ;AAEhB,cAAAJ,OAAA,+IAAAI,eAAA,QAAA,MAAM,QAAQ,CAAA,cAAA;AAAA;;;;;;;AAMf,cAAA,QAAA,OAAO,gBAAc;AAKc,YAAAJ,OAAA,iWAAAI,eAAA,QAAA,MAAM,cAAc,CAAA,iCAAA;AAAA;;;AAMvD,cAAA,QAAA,OAAO,aAAW;AAEtB,YAAAJ,OAAA,iKAAAI,eAAA,QAAA,MAAM,WAAW,CAAA,cAAA;AAAA;;;;;;;;;;;;;;;;;;","names":["_push","_ssrRenderComponent","_unref","EyeIcon","_ssrInterpolate","_ssrRenderStyle","XIcon","_ssrRenderList"],"sources":["../../../../components/TacheDetailModal.vue"],"sourcesContent":["<template>\n  <Teleport to=\"body\">\n    <div v-if=\"isOpen\" class=\"modal-overlay\" @click.self=\"$emit('close')\">\n      <div class=\"detail-modal\" @click.stop>\n        <!-- Header -->\n        <div class=\"detail-modal-header\">\n          <div style=\"display:flex; align-items:center; gap:0.75rem; flex:1; min-width:0;\">\n            <div class=\"detail-icon-wrap\">\n              <EyeIcon :size=\"16\" />\n            </div>\n            <div style=\"min-width:0;\">\n              <div style=\"font-weight:700; font-size:0.9375rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\">{{ tache?.titre }}</div>\n              <div style=\"font-size:0.75rem; color:var(--text-secondary); margin-top:1px;\">\n                Détail de la tâche\n              </div>\n            </div>\n          </div>\n          <div style=\"display:flex; align-items:center; gap:0.75rem; flex-shrink:0;\">\n            <span v-if=\"tache?.statutTache\" class=\"badge\" :style=\"{background: tache.statutTache.couleur + '20', color: tache.statutTache.couleur, border: '1px solid ' + tache.statutTache.couleur}\">\n              {{ tache.statutTache.nom }}\n            </span>\n            <button class=\"modal-close-btn\" @click=\"$emit('close')\">\n              <XIcon :size=\"16\" />\n            </button>\n          </div>\n        </div>\n\n        <!-- Body -->\n        <div class=\"detail-modal-body\">\n\n          <!-- SECTION: Assignation & Dates -->\n          <div class=\"detail-section\">\n            <div class=\"detail-section-title\">Informations générales</div>\n            <div class=\"detail-grid\">\n              <div class=\"detail-field\" v-if=\"tache?.employe\">\n                <div class=\"detail-label\">Assigné à</div>\n                <div class=\"detail-value detail-value-bold\">\n                  <div class=\"detail-avatar\">{{ tache.employe.prenom?.charAt(0) }}{{ tache.employe.nom?.charAt(0) }}</div>\n                  {{ tache.employe.prenom }} {{ tache.employe.nom }}\n                </div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.edition\">\n                <div class=\"detail-label\">Page / Événement</div>\n                <div class=\"detail-value\">{{ tache.edition.licence?.sigle }} — {{ tache.edition.ville?.nom_ville }}</div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.demandeur\">\n                <div class=\"detail-label\">Demandeur</div>\n                <div class=\"detail-value\">{{ tache.demandeur }}</div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.date_limite\">\n                <div class=\"detail-label\">Deadline</div>\n                <div class=\"detail-value\" :style=\"{color: isLate ? 'var(--status-danger)' : 'inherit', fontWeight: isLate ? '600' : '500'}\">\n                  {{ formatDate(tache.date_limite) }}\n                  <span v-if=\"isLate\" style=\"font-size:0.7rem; margin-left:4px;\">⚠ Dépassée</span>\n                </div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.createdAt\">\n                <div class=\"detail-label\">Créée le</div>\n                <div class=\"detail-value\">{{ formatDate(tache.createdAt) }}</div>\n              </div>\n            </div>\n          </div>\n\n          <!-- SECTION: CM - Publication -->\n          <div class=\"detail-section\" v-if=\"tache?.plateforme || tache?.type_pub\">\n            <div class=\"detail-section-title\">Publication</div>\n            <div class=\"detail-grid\">\n              <div class=\"detail-field\" v-if=\"tache?.plateforme\">\n                <div class=\"detail-label\">Plateformes</div>\n                <div class=\"detail-value\" style=\"display:flex; gap:0.4rem; flex-wrap:wrap;\">\n                  <span v-for=\"pl in parsePlateforme(tache.plateforme)\" :key=\"pl\" class=\"badge badge-primary\">{{ pl }}</span>\n                </div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.type_pub\">\n                <div class=\"detail-label\">Type de publication</div>\n                <div class=\"detail-value\"><span class=\"badge badge-neutral\">{{ tache.type_pub }}</span></div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.themePub\">\n                <div class=\"detail-label\">Thème du post</div>\n                <div class=\"detail-value\">{{ tache.themePub?.nom_theme }}</div>\n              </div>\n            </div>\n          </div>\n\n          <!-- SECTION: CM - Démarche Administrative -->\n          <div class=\"detail-section\" v-if=\"tache?.type_demarche\">\n            <div class=\"detail-section-title\">Démarche Administrative</div>\n            <div class=\"detail-grid\">\n              <div class=\"detail-field\">\n                <div class=\"detail-label\">Type de démarche</div>\n                <div class=\"detail-value\">{{ tache.type_demarche }}</div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.date_demande\">\n                <div class=\"detail-label\">Date limite Demande</div>\n                <div class=\"detail-value\">{{ formatDateShort(tache.date_demande) }}</div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.date_resultat\">\n                <div class=\"detail-label\">Date limite Résultat</div>\n                <div class=\"detail-value\">{{ formatDateShort(tache.date_resultat) }}</div>\n              </div>\n            </div>\n          </div>\n\n          <!-- SECTION: CM - Mailing -->\n          <div class=\"detail-section\" v-if=\"tache?.outil_mailing\">\n            <div class=\"detail-section-title\">Mailing / Newsletter</div>\n            <div class=\"detail-grid\">\n              <div class=\"detail-field\">\n                <div class=\"detail-label\">Outil</div>\n                <div class=\"detail-value\"><span class=\"badge badge-info\">{{ tache.outil_mailing }}</span></div>\n              </div>\n            </div>\n          </div>\n\n          <!-- SECTION: CM - Sponsorisation -->\n          <div class=\"detail-section\" v-if=\"tache?.budget || tache?.audience\">\n            <div class=\"detail-section-title\">Sponsorisation (Ads)</div>\n            <div class=\"detail-grid\">\n              <div class=\"detail-field\" v-if=\"tache?.themeSponso\">\n                <div class=\"detail-label\">Thème à sponsoriser</div>\n                <div class=\"detail-value\">{{ tache.themeSponso?.nom_theme }}</div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.budget\">\n                <div class=\"detail-label\">Budget alloué</div>\n                <div class=\"detail-value\" style=\"font-weight:700; color:var(--accent-primary);\">{{ tache.budget }} €</div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.audience\">\n                <div class=\"detail-label\">Ciblage / Audience</div>\n                <div class=\"detail-value\">{{ tache.audience }}</div>\n              </div>\n            </div>\n          </div>\n\n          <!-- SECTION: Monteur Vidéo -->\n          <div class=\"detail-section\" v-if=\"tache?.format_video || tache?.duree_cible\">\n            <div class=\"detail-section-title\">Montage Vidéo</div>\n            <div class=\"detail-grid\">\n              <div class=\"detail-field\" v-if=\"tache?.format_video\">\n                <div class=\"detail-label\">Format vidéo</div>\n                <div class=\"detail-value\"><span class=\"badge badge-neutral\">{{ tache.format_video }}</span></div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.duree_cible\">\n                <div class=\"detail-label\">Durée cible</div>\n                <div class=\"detail-value\">{{ tache.duree_cible }}</div>\n              </div>\n            </div>\n          </div>\n\n          <!-- SECTION: Designer -->\n          <div class=\"detail-section\" v-if=\"tache?.type_visuel || tache?.quantite\">\n            <div class=\"detail-section-title\">Création Graphique</div>\n            <div class=\"detail-grid\">\n              <div class=\"detail-field\" v-if=\"tache?.type_visuel\">\n                <div class=\"detail-label\">Type de visuel</div>\n                <div class=\"detail-value\"><span class=\"badge badge-neutral\">{{ tache.type_visuel }}</span></div>\n              </div>\n              <div class=\"detail-field\" v-if=\"tache?.quantite\">\n                <div class=\"detail-label\">Quantité</div>\n                <div class=\"detail-value\">{{ tache.quantite }}</div>\n              </div>\n            </div>\n          </div>\n\n          <!-- SECTION: Développeur -->\n          <div class=\"detail-section\" v-if=\"tache?.type_technique\">\n            <div class=\"detail-section-title\">Développement</div>\n            <div class=\"detail-grid\">\n              <div class=\"detail-field\">\n                <div class=\"detail-label\">Type technique</div>\n                <div class=\"detail-value\"><span class=\"badge badge-neutral\">{{ tache.type_technique }}</span></div>\n              </div>\n            </div>\n          </div>\n\n          <!-- SECTION: Description / Notes -->\n          <div class=\"detail-section\" v-if=\"tache?.description\">\n            <div class=\"detail-section-title\">Notes & Brief</div>\n            <div class=\"detail-desc\">{{ tache.description }}</div>\n          </div>\n\n        </div>\n\n        <!-- Footer -->\n        <div class=\"detail-modal-footer\">\n          <button class=\"btn btn-secondary\" @click=\"$emit('close')\">Fermer</button>\n        </div>\n      </div>\n    </div>\n  </Teleport>\n</template>\n\n<script setup>\nimport { computed } from 'vue'\nimport { Eye as EyeIcon, X as XIcon } from 'lucide-vue-next'\n\nconst props = defineProps({\n  isOpen: { type: Boolean, default: false },\n  tache: { type: Object, default: null }\n})\n\ndefineEmits(['close'])\n\nconst isLate = computed(() => {\n  if (!props.tache?.date_limite) return false\n  const st = props.tache?.statutTache?.nom\n  if (st === 'Terminé' || st === 'Publié') return false\n  return new Date(props.tache.date_limite) < new Date()\n})\n\nconst formatDate = (d) => {\n  if (!d) return '—'\n  return new Date(d).toLocaleString('fr-FR', { dateStyle: 'short', timeStyle: 'short' })\n}\n\nconst formatDateShort = (d) => {\n  if (!d) return '—'\n  return new Date(d).toLocaleDateString('fr-FR')\n}\n\nconst parsePlateforme = (val) => {\n  if (!val) return []\n  try { return JSON.parse(val) } catch { return val.split(',').map(s => s.trim()) }\n}\n</script>\n\n<style scoped>\n.modal-overlay {\n  position: fixed;\n  inset: 0;\n  background: rgba(0,0,0,0.45);\n  backdrop-filter: blur(4px);\n  z-index: 9999;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  padding: 1.5rem;\n  animation: fadeIn 0.15s ease;\n}\n\n@keyframes fadeIn { from { opacity:0 } to { opacity:1 } }\n\n.detail-modal {\n  background: var(--bg-surface);\n  border: 1px solid var(--border-light);\n  border-radius: 12px;\n  width: 100%;\n  max-width: 640px;\n  max-height: 85vh;\n  display: flex;\n  flex-direction: column;\n  box-shadow: 0 20px 60px rgba(0,0,0,0.2);\n  animation: slideUp 0.2s ease;\n}\n\n@keyframes slideUp { from { transform: translateY(12px); opacity:0 } to { transform: translateY(0); opacity:1 } }\n\n.detail-modal-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 1rem;\n  padding: 1rem 1.25rem;\n  border-bottom: 1px solid var(--border-light);\n  flex-shrink: 0;\n}\n\n.detail-icon-wrap {\n  width: 32px;\n  height: 32px;\n  border-radius: 8px;\n  background: var(--accent-primary);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: white;\n  flex-shrink: 0;\n}\n\n.modal-close-btn {\n  background: var(--bg-surface-hover);\n  border: 1px solid var(--border-light);\n  border-radius: 6px;\n  padding: 0.3rem;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n  color: var(--text-secondary);\n  transition: all 0.12s;\n}\n.modal-close-btn:hover { background: var(--bg-hover); color: var(--text-primary); }\n\n.detail-modal-body {\n  overflow-y: auto;\n  padding: 1.25rem;\n  display: flex;\n  flex-direction: column;\n  gap: 1.25rem;\n  flex: 1;\n}\n\n.detail-section {\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n}\n\n.detail-section-title {\n  font-size: 0.6875rem;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  color: var(--text-muted);\n  padding-bottom: 0.5rem;\n  border-bottom: 1px solid var(--border-light);\n}\n\n.detail-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 0.75rem 1.5rem;\n}\n\n.detail-field {}\n\n.detail-label {\n  font-size: 0.7rem;\n  font-weight: 600;\n  color: var(--text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.03em;\n  margin-bottom: 0.2rem;\n}\n\n.detail-value {\n  font-size: 0.875rem;\n  color: var(--text-primary);\n  font-weight: 500;\n  display: flex;\n  align-items: center;\n  gap: 0.4rem;\n  flex-wrap: wrap;\n}\n\n.detail-value-bold { font-weight: 600; }\n\n.detail-avatar {\n  width: 22px;\n  height: 22px;\n  border-radius: 50%;\n  background: var(--accent-blue);\n  color: white;\n  font-size: 0.6rem;\n  font-weight: 700;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n}\n\n.detail-desc {\n  font-size: 0.875rem;\n  color: var(--text-secondary);\n  background: var(--bg-surface-hover);\n  border: 1px solid var(--border-light);\n  border-radius: 8px;\n  padding: 0.75rem 1rem;\n  line-height: 1.6;\n  white-space: pre-wrap;\n}\n\n.detail-modal-footer {\n  padding: 0.875rem 1.25rem;\n  border-top: 1px solid var(--border-light);\n  display: flex;\n  justify-content: flex-end;\n  flex-shrink: 0;\n}\n</style>\n"],"version":3}