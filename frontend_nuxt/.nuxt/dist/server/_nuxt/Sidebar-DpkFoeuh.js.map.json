AC7B;AAAA;;;;;;UACU,IAAG;AAAA,UAAoB,OAAM;AAAA,UAAW,gBAAa;AAAA;2BAA/D,CAEW,GAAAf,QAAAC,UAAA,aAAA;;AADM,cAAAD,OAAAE,mBAAAC,MAAAa,QAAA,GAAA,EAAA,MAAM,MAAE,MAAAf,UAAA,QAAA,CAAA;;;;gBAAvBI,YAA2BF,MAAAa,QAAA,GAAA,EAAZ,MAAM,GAAE,CAAA;AAAA,gCAAI,gBAC7B;AAAA;;;;;;;UAKU,IAAG;AAAA,UAAkB,OAAM;AAAA,UAAW,gBAAa;AAAA;2BAA7D,CAEW,GAAAhB,QAAAC,UAAA,aAAA;;AADE,cAAAD,OAAAE,mBAAAC,MAAAc,IAAA,GAAA,EAAA,MAAM,MAAE,MAAAhB,UAAA,QAAA,CAAA;;;;gBAAnBI,YAAuBF,MAAAc,IAAA,GAAA,EAAZ,MAAM,GAAE,CAAA;AAAA,gCAAI,cACzB;AAAA;;;;;;;;;gDAMD,EAAA,cAAA,iCAAA,eAAA,WAAA,cAAA,UAAA,CAA6F,iDAC3F,EAAA,WAAA,QAAA,eAAA,UAAA,OAAA,UAAA,WAAA,UAAA,iBAAA,OAAA,cAAA,2BAAA,iBAAA,SAAA,CAAyJ,iDACvJ,EAAA,SAAA,QAAA,UAAA,QAAA,iBAAA,OAAA,cAAA,sBAAA,WAAA,QAAA,eAAA,UAAA,mBAAA,UAAA,SAAA,SAAA,aAAA,UAAA,eAAA,MAAA,CAAsM,qCACtM,SAAA,KAAQ,qCAER,EAAA,QAAA,KAAA,aAAA,IAAA,CAA8B,iDAC5B,EAAA,aAAA,aAAA,eAAA,OAAA,eAAA,UAAA,YAAA,UAAA,iBAAA,WAAA,CAA+G,qCAC/G,SAAA,KAAQ,qCAER,EAAA,aAAA,aAAA,SAAA,oBAAA,CAAuD,qCAAI,MAAA,KAAK;;QAG/D,IAAG;AAAA,QAAI,OAAM;AAAA,QAAW,OAAA,EAAA,SAAA,oBAAA;AAAA;yBAAlC,CAEW,GAAAjB,QAAAC,UAAA,aAAA;;AADI,YAAAD,OAAAE,mBAAAC,MAAAe,MAAA,GAAA,EAAA,MAAM,MAAE,MAAAjB,UAAA,QAAA,CAAA;;;;cAArBI,YAAyBF,MAAAe,MAAA,GAAA,EAAZ,MAAM,GAAE,CAAA;AAAA,8BAAI,eAC3B;AAAA;;;;;;;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_push","_parent","_ssrRenderComponent","_unref","LayoutDashboardIcon","_createVNode","MegaphoneIcon","FilmIcon","PaletteIcon","CodeIcon","BarChart2Icon","UsersIcon","LinkIcon","SettingsIcon","GlobeIcon","ListTodoIcon","CalendarIcon","UserIcon","LogOutIcon"],"sources":["../../../../components/Sidebar.vue"],"sourcesContent":["<template>\n  <aside class=\"layout-sidebar\">\n    <!-- Logo -->\n    <div style=\"display: flex; align-items: center; gap: 0.5rem; padding: 0 0.5rem; margin-bottom: 1.5rem;\">\n      <div style=\"width: 26px; height: 26px; background: var(--accent-primary); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 0.7rem;\">ES</div>\n      <span style=\"font-size: 1rem; font-weight: 700; letter-spacing: -0.02em;\">EventSync</span>\n    </div>\n\n    <nav style=\"display: flex; flex-direction: column; gap: 1.25rem; flex: 1; overflow-y: auto;\">\n\n      <!-- ADMIN NAV -->\n      <template v-if=\"role === 'admin'\">\n        <!-- Overview -->\n        <div>\n          <div class=\"nav-section-title\">Overview</div>\n          <NuxtLink to=\"/admin\" class=\"nav-link\" exact-active-class=\"nav-link-active\">\n            <LayoutDashboardIcon :size=\"15\" /> Dashboard\n          </NuxtLink>\n        </div>\n\n        <!-- Tâches par Département -->\n        <div>\n          <div class=\"nav-section-title\">Tâches par Département</div>\n          <NuxtLink to=\"/admin/taches/cm\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <MegaphoneIcon :size=\"15\" /> Community Managers\n          </NuxtLink>\n          <NuxtLink to=\"/admin/taches/monteur\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <FilmIcon :size=\"15\" /> Monteurs Vidéo\n          </NuxtLink>\n          <NuxtLink to=\"/admin/taches/designer\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <PaletteIcon :size=\"15\" /> Designers\n          </NuxtLink>\n          <NuxtLink to=\"/admin/taches/dev\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <CodeIcon :size=\"15\" /> Développeurs Web\n          </NuxtLink>\n        </div>\n\n        <!-- Analyse -->\n        <div>\n          <div class=\"nav-section-title\">Analyse</div>\n          <NuxtLink to=\"/admin/meta\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <BarChart2Icon :size=\"15\" /> Meta Ads\n          </NuxtLink>\n        </div>\n\n        <!-- Gestion -->\n        <div>\n          <div class=\"nav-section-title\">Gestion</div>\n          <NuxtLink to=\"/admin/equipe\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <UsersIcon :size=\"15\" /> Équipe & Rôles\n          </NuxtLink>\n          <NuxtLink to=\"/admin/affectations\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <LinkIcon :size=\"15\" /> Affectations\n          </NuxtLink>\n        </div>\n\n        <!-- Configuration -->\n        <div>\n          <div class=\"nav-section-title\">Configuration</div>\n          <NuxtLink to=\"/admin/parametres\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <SettingsIcon :size=\"15\" /> Événements & Villes\n          </NuxtLink>\n          <NuxtLink to=\"/admin/plateformes\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <GlobeIcon :size=\"15\" /> Plateformes\n          </NuxtLink>\n        </div>\n      </template>\n\n      <!-- EMPLOYEE NAV -->\n      <template v-if=\"role === 'employe'\">\n        <div>\n          <div class=\"nav-section-title\">Overview</div>\n          <NuxtLink to=\"/employe\" class=\"nav-link\" exact-active-class=\"nav-link-active\">\n            <LayoutDashboardIcon :size=\"15\" /> Dashboard\n          </NuxtLink>\n        </div>\n\n        <div>\n          <div class=\"nav-section-title\">Mon Activité</div>\n          <NuxtLink to=\"/employe/taches\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <ListTodoIcon :size=\"15\" /> Mes Tâches\n          </NuxtLink>\n          <NuxtLink to=\"/employe/planning\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <CalendarIcon :size=\"15\" /> Mon Planning\n          </NuxtLink>\n        </div>\n\n        <div>\n          <div class=\"nav-section-title\">Compte</div>\n          <NuxtLink to=\"/employe/profil\" class=\"nav-link\" active-class=\"nav-link-active\">\n            <UserIcon :size=\"15\" /> Mon Profil\n          </NuxtLink>\n        </div>\n      </template>\n    </nav>\n\n    <!-- Bottom -->\n    <div style=\"border-top: 1px solid var(--border-light); padding-top: 0.75rem; margin-top: 0.75rem;\">\n      <div style=\"display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem; border-radius: 6px; background: var(--bg-surface-hover); margin-bottom: 0.5rem;\">\n        <div style=\"width: 28px; height: 28px; border-radius: 50%; background: var(--accent-blue); display: flex; align-items: center; justify-content: center; color: white; font-size: 0.7rem; font-weight: 600;\">\n          {{ initials }}\n        </div>\n        <div style=\"flex: 1; min-width: 0;\">\n          <div style=\"font-size: 0.8125rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;\">\n            {{ fullName }}\n          </div>\n          <div style=\"font-size: 0.6875rem; color: var(--text-muted);\">{{ email }}</div>\n        </div>\n      </div>\n      <NuxtLink to=\"/\" class=\"nav-link\" style=\"color: var(--text-muted);\">\n        <LogOutIcon :size=\"15\" /> Déconnexion\n      </NuxtLink>\n    </div>\n  </aside>\n</template>\n\n<script setup>\nimport { computed } from 'vue'\nimport { useCookie, useFetch } from '#imports'\nimport {\n  LayoutDashboard as LayoutDashboardIcon,\n  Megaphone as MegaphoneIcon,\n  Film as FilmIcon,\n  Palette as PaletteIcon,\n  Code as CodeIcon,\n  Users as UsersIcon,\n  Link as LinkIcon,\n  Settings as SettingsIcon,\n  Globe as GlobeIcon,\n  ListTodo as ListTodoIcon,\n  Calendar as CalendarIcon,\n  User as UserIcon,\n  LogOut as LogOutIcon,\n  BarChart2 as BarChart2Icon\n} from 'lucide-vue-next'\n\nconst props = defineProps({\n  role: { type: String, required: true }\n})\n\nconst loggedEmployeId = useCookie('employe_id')\nconst { data: employes } = await useFetch('/api/equipe')\nconst myEmployeInfo = computed(() => employes.value?.find(e => e.id === loggedEmployeId.value))\n\nconst initials = computed(() => {\n  if (props.role === 'admin') return 'AD'\n  if (myEmployeInfo.value) return `${myEmployeInfo.value.prenom.charAt(0)}${myEmployeInfo.value.nom.charAt(0)}`.toUpperCase()\n  return 'EM'\n})\n\nconst fullName = computed(() => {\n  if (props.role === 'admin') return 'Administrateur'\n  if (myEmployeInfo.value) return `${myEmployeInfo.value.prenom} ${myEmployeInfo.value.nom}`\n  return 'Employé'\n})\n\nconst email = computed(() => {\n  if (props.role === 'admin') return 'admin@eventsync.local'\n  if (myEmployeInfo.value) return myEmployeInfo.value.email\n  return 'employe@eventsync.local'\n})\n</script>\n\n<style scoped>\n.nav-section-title {\n  font-size: 0.6875rem;\n  font-weight: 600;\n  color: var(--text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n  padding: 0 0.5rem;\n  margin-bottom: 0.375rem;\n}\n\n.nav-link {\n  display: flex;\n  align-items: center;\n  gap: 0.625rem;\n  padding: 0.4rem 0.5rem;\n  border-radius: 6px;\n  color: var(--text-secondary);\n  text-decoration: none;\n  font-weight: 500;\n  font-size: 0.8125rem;\n  transition: all 0.12s ease;\n}\n\n.nav-link:hover {\n  background: var(--bg-surface-hover);\n  color: var(--text-primary);\n}\n\n.nav-link-active {\n  background: #f3f4f6;\n  color: var(--text-primary);\n  font-weight: 600;\n}\n</style>\n"],"version":3}