# ─── Base de données (PostgreSQL - Neon) ───────────────────────────
# URL poolée (pour les requêtes Prisma en production via PgBouncer)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# URL directe (pour prisma migrate — bypasse le pooler)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Auth JWT ────────────────────────────────────────────────────────
# Générer une clé forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret

# ─── Meta Marketing API ─────────────────────────────────────────────
META_SYSTEM_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_PAGE_IDS=
META_AD_ACCOUNT_IDS=

# ─── Google Sheets ───────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# ─── Groq AI ────────────────────────────────────────────────────────
GROQ_API_KEY=
